# Copy to .env for local development (make db && make migrate && make dev).

WALDI_ADDR=:8080
WALDI_ENV=dev
WALDI_BASE_DOMAIN=waldi.blog
WALDI_DATABASE_URL=postgres://waldi:waldi@localhost:5432/waldi?sslmode=disable

# Telegram admin bot (replaces the old HTTP admin panel).
# Create a bot via @BotFather, then set your Telegram user id(s) from @userinfobot.
# WALDI_TELEGRAM_BOT_TOKEN=123456:ABC...
# WALDI_TELEGRAM_ADMIN_IDS=123456789
# Optional: override the signup link base (default: https://WALDI_BASE_DOMAIN)
# WALDI_APP_URL=https://waldi.blog

# Local subdomain testing:
#   App / feed:  http://localhost:8080
#   Your blog:   http://YOUR_USERNAME.localhost:8080
#
# For production-like cookie sharing, use waldi.test instead:
#   127.0.0.1 waldi.test
#   127.0.0.1 user.waldi.test

# --- Production SMTP (transactional email) ---
# Works with any SMTP provider: Postmark, SendGrid, Mailgun, Amazon SES, etc.
# WALDI_SMTP_HOST=smtp.postmarkapp.com
# WALDI_SMTP_PORT=587
# WALDI_SMTP_USERNAME=your-server-token
# WALDI_SMTP_PASSWORD=your-server-token
# WALDI_SMTP_FROM=no-reply@waldi.blog

# --- MinIO / S3 image storage ---
# Images are resized (max 1600px wide) and converted to WebP before upload.
# WALDI_S3_ENDPOINT=minio.example.com:9000
# WALDI_S3_ACCESS_KEY=your-access-key
# WALDI_S3_SECRET_KEY=your-secret-key
# WALDI_S3_BUCKET=waldi
# WALDI_S3_USE_SSL=true
# Public URL for uploaded images (CDN or MinIO public bucket URL).
# Leave empty to serve via the app at /media/{username}/{file}.webp
# WALDI_S3_PUBLIC_URL=https://cdn.waldi.blog/waldi

# Local MinIO (make db starts it):
# WALDI_S3_ENDPOINT=localhost:9000
# WALDI_S3_ACCESS_KEY=waldi
# WALDI_S3_SECRET_KEY=waldi-secret
# WALDI_S3_BUCKET=waldi
# WALDI_S3_USE_SSL=false

# --- Production deploy (docker compose -f docker-compose.prod.yml) ---
# See DEPLOY.md for the full guide.
#
# WALDI_ENV=prod
# POSTGRES_PASSWORD=change-me
# CLOUDFLARE_API_TOKEN=your-cloudflare-dns-token
# CADDY_EMAIL=you@waldi.blog
#
# Optional: Cloudflare CDN cache purge on publish (same token, Zone:Cache Purge permission)
# WALDI_CF_ZONE_ID=your-zone-id
#
# Database backups (deploy/backup-db.sh → R2, uses WALDI_S3_* above)
# WALDI_BACKUP_PREFIX=backups
# BACKUP_RETENTION_DAYS=7
